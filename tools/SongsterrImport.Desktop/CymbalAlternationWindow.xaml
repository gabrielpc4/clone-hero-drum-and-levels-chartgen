<Window x:Class="SongsterrImport.Desktop.CymbalAlternationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="Cymbal Alternation Tool — tick OCR + preview (v2)"
        Height="900"
        Width="820"
        MinHeight="720"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Loaded="OnWindowLoaded"
        Closing="OnWindowClosing">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="240" MinHeight="200"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="MIDI file" />
            <TextBox x:Name="MidiPathTextBox" Grid.Column="1" VerticalContentAlignment="Center" />
            <Button Grid.Column="2" Margin="8,0,0,0" Padding="10,4" Content="Browse..." Click="OnBrowseMidiClick" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Start tick" />
            <TextBox x:Name="StartTickTextBox" Grid.Column="1" VerticalContentAlignment="Center" />
            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="16,0,8,0" Text="End tick" />
            <TextBox x:Name="EndTickTextBox" Grid.Column="3" VerticalContentAlignment="Center" />
            <Button Grid.Column="4" Margin="12,0,0,0" Width="32" Height="28" Content="+" Click="OnAddIntervalClick" />
            <Button Grid.Column="5" Margin="8,0,0,0" Width="32" Height="28" Content="-" Click="OnRemoveIntervalClick" />
            <Button Grid.Column="6" Margin="12,0,0,0" Padding="10,4" HorizontalAlignment="Left" Content="Clear intervals" Click="OnClearIntervalsClick" />
        </Grid>

        <GroupBox Grid.Row="2" Header="OCR: tick from another window (Windows.Media.Ocr)" Padding="6" Margin="0,0,0,6">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Target window" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="OcrTargetCombo" Grid.Column="1" IsEditable="False" VerticalContentAlignment="Center" MinWidth="280"
                              DisplayMemberPath="ListLabel" SelectionChanged="OnOcrTargetChanged"/>
                    <Button Grid.Column="2" Content="List windows" Margin="8,0,0,0" Padding="8,2" Click="OnRefreshWindowListClick"/>
                    <Button x:Name="OcrRefreshPreviewButton" Grid.Column="3" Content="Refresh preview" Margin="6,0,0,0" Padding="8,2" Click="OnRefreshOcrPreviewClick"/>
                    <CheckBox x:Name="OcrDrawRegionCheck" Grid.Column="4" Content="Draw OCR region" Margin="8,0,0,0" VerticalAlignment="Center" Checked="OnOcrDrawRegionToggled" Unchecked="OnOcrDrawRegionToggled"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Preview: full client capture + green = OCR area (letterboxed)" Padding="0">
            <wfi:WindowsFormsHost x:Name="RegionPreviewHost" Margin="4" />
        </GroupBox>

        <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,4,0,4">
            <TextBlock x:Name="OcrFieldHintText" TextWrapping="Wrap" Text="OCR: first read fills Start, second fills End and then adds the interval. Third read starts a new range at Start."/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button x:Name="OcrReadButton" Content="Read tick (OCR from region) → next field" Padding="10,5" MinWidth="280" Click="OnOcrReadClick"/>
            </StackPanel>
        </StackPanel>

        <GroupBox Grid.Row="5" Header="Intervals" Margin="0,4,0,4">
            <ListBox x:Name="IntervalsListBox" Margin="8" />
        </GroupBox>

        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,2,0,4">
            <Button x:Name="ExecuteButton" Content="Apply Alternation" Padding="12,5" Click="OnApplyAlternationClick" />
        </StackPanel>

        <GroupBox Grid.Row="7" Header="Result" Margin="0,0,0,0">
            <TextBox x:Name="ResultTextBox"
                     Margin="8"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="11" />
        </GroupBox>
    </Grid>
</Window>
