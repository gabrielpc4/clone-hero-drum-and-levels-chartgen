<Window x:Class="SongsterrImport.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Sign in to Songsterr"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <wv2:WebView2 x:Name="Browser" Grid.Row="0" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8">
            <TextBlock Text="Sign in on the site, then click save."
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" TextWrapping="Wrap" MaxWidth="420" />
            <Button x:Name="SaveButton" Content="Save cookies and close" Padding="12,6" Click="OnSaveCookiesClick" />
        </StackPanel>
    </Grid>
</Window>
